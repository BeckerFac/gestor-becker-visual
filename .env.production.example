# ============================================
# GESTOR BECKERVISU AL - PRODUCTION ENV VARS
# ============================================
# Copy this file to .env and fill in your values

# ============ SERVER ============
NODE_ENV=production
PORT=3000

# ============ DATABASE (PostgreSQL en la nube) ============
# Para Heroku: Automáticamente asignado (DATABASE_URL)
# Para Railway: DATABASE_URL
# Para AWS RDS: postgresql://user:pass@host:5432/dbname
DATABASE_URL=postgresql://user:password@your-db-host.com:5432/gestor_becker

# ============ JWT SECRETS (Generar valores seguros!) ============
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-very-long-random-secret-key-at-least-32-chars
JWT_REFRESH_SECRET=another-very-long-random-secret-key-at-least-32-chars
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ============ AFIP CONFIG ============
# Para producción: Usar AFIP_ENV=produccion y certificado real
# Para testing: Usar AFIP_ENV=homologacion
AFIP_ENV=homologacion
AFIP_CUIT=20123456789
AFIP_CERT_PATH=/path/to/cert.pem
AFIP_KEY_PATH=/path/to/key.pem

# ============ EMAIL (SMTP) ============
# Recomendado: Gmail con App Password
# https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
SMTP_FROM=noreply@gestorbecker.com

# ============ CORS ============
# Debe ser la URL exacta del frontend
CORS_ORIGIN=https://gestor-becker.vercel.app

# ============ LOGGING ============
LOG_LEVEL=info

# ============ RATE LIMITING ============
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
